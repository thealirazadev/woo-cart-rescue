# EditorConfig matching the WordPress Coding Standards used by this plugin.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab

# PHP, JS, and CSS follow WPCS: real tabs for indentation.
[*.{php,js,css}]
indent_style = tab

# YAML and JSON do not allow tabs for indentation.
[*.{yml,yaml,json}]
indent_style = space
indent_size = 2

# Markdown: keep trailing whitespace, which can be a hard line break.
[*.md]
trim_trailing_whitespace = false

# The .pot catalog is generated; leave it untouched.
[*.pot]
insert_final_newline = false
trim_trailing_whitespace = false
